<mujoco model="elastic_tether">
  <option timestep="0.002" gravity="0 0 0" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>
    <geom name="floor" type="plane" size="1 1 0.1" pos="0 0 -0.05"
          rgba="0.4 0.4 0.4 0.3" contype="0" conaffinity="0"/>

    <body name="anchor" pos="0 0 0">
      <geom type="sphere" size="0.015" rgba="0.85 0.2 0.2 1"/>
      <site name="anchor_site" size="0.005"/>
    </body>

    <!-- EE 是纯 mocap body：位置精确由 data.mocap_pos[0] 给定，
         模拟位置控制机械臂末端。site 直接挂在这里，tendon 几何正确。
         没有自由体，没有 weld，不引入弹簧质量振荡。 -->
    <body name="ee" mocap="true" pos="0.12 0 0">
      <geom type="sphere" size="0.02" rgba="0.2 0.8 0.2 1"
            contype="0" conaffinity="0"/>
      <site name="ee_site" size="0.005"/>
    </body>
  </worldbody>

  <tendon>
    <spatial name="elastic_tether"
             stiffness="50.0" damping="0.5" springlength="0 0.25"
             width="0.005" rgba="0.95 0.75 0.1 1">
      <site site="anchor_site"/>
      <site site="ee_site"/>
    </spatial>
  </tendon>
</mujoco>